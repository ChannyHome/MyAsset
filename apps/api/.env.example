APP_NAME=MyAsset API
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://myasset:myasset@127.0.0.1:3306/myasset
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
API_ACCESS_LOG_ENABLED=false
API_ACCESS_LOG_DIR=logs/api
API_AUDIT_LOG_ENABLED=true
API_AUDIT_LOG_MAX_BODY_CHARS=4096
QUOTE_AUTO_UPDATE_ENABLED=false
QUOTE_UPDATE_INTERVAL_MINUTES=10
QUOTE_PROVIDER=yfinance
FX_STRICT_MODE=false
FX_STALE_MINUTES=30
VALUATION_SNAPSHOT_AUTO_COLLECT_ENABLED=true
VALUATION_SNAPSHOT_COLLECT_CURRENCY=KRW
DATA_GO_KR_SERVICE_KEY=
DATA_GO_KR_APARTMENT_TRADE_URL=https://apis.data.go.kr/1613000/RTMSDataSvcAptTradeDev/getRTMSDataSvcAptTradeDev
DATA_GO_KR_TIMEOUT_SECONDS=10
DATA_GO_KR_ROWS_PER_CALL=1000
DATA_GO_KR_LOOKBACK_MONTHS=6
APP_SECRETS_MASTER_KEY=
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
