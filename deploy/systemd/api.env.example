# Copy to: /etc/myasset/api.env
# Adjust values for your server.

DATABASE_URL=mysql+pymysql://myasset:change_me@127.0.0.1:3306/myasset
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Comma-separated origins. For same-domain deploy, keep your domain here.
CORS_ALLOW_ORIGINS=https://your-domain.com

# Optional runtime settings
API_ACCESS_LOG_ENABLED=true
API_ACCESS_LOG_DIR=logs/api
QUOTE_AUTO_UPDATE_ENABLED=true
QUOTE_UPDATE_INTERVAL_MINUTES=10

